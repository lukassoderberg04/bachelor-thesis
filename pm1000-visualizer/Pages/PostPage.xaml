<UserControl x:Class="pm1000_visualizer.Pages.PostPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:h="clr-namespace:HelixToolkit.Wpf;assembly=HelixToolkit.Wpf"
             Background="#FF28292B">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Header + save -->
            <RowDefinition Height="Auto"/>
            <!-- Summary -->
            <RowDefinition Height="3*"/>
            <!-- Poincaré sphere -->
            <RowDefinition Height="Auto"/>
            <!-- Processed audio -->
            <RowDefinition Height="Auto"/>
            <!-- Raw audio -->
            <RowDefinition Height="Auto"/>
            <!-- New Measurement -->
        </Grid.RowDefinitions>

        <!-- ═══ Row 0: Header + save ═══════════════════════════════════ -->
        <StackPanel Margin="0,0,0,8">
            <TextBlock Text="PM1000 Post"
                       FontSize="20"
                       FontWeight="Bold"
                       Foreground="White"/>

            <StackPanel Orientation="Horizontal"
                        Margin="0,10,0,0">
                <Button Content="💾  Save All to Folder…"
                        Style="{StaticResource AccentButton}"
                        FontSize="13"
                        Padding="14,7"
                        Click="SaveAll_Click"/>
                <Button Content="Save Stokes CSV"
                        Style="{StaticResource DarkButton}"
                        Margin="10,0,0,0"
                        FontSize="12"
                        Padding="10,6"
                        Click="SaveStokes_Click"/>
                <Button Content="Save Raw Audio"
                        Style="{StaticResource DarkButton}"
                        Margin="6,0,0,0"
                        FontSize="12"
                        Padding="10,6"
                        Click="SaveRawAudio_Click"/>
                <Button Content="Save Processed Audio"
                        Style="{StaticResource DarkButton}"
                        Margin="6,0,0,0"
                        FontSize="12"
                        Padding="10,6"
                        Click="SaveProcessedAudio_Click"/>
            </StackPanel>

            <TextBlock x:Name="SaveStatusText"
                       Foreground="#FF90EE90"
                       FontSize="12"
                       Margin="0,6,0,0"
                       Visibility="Collapsed"/>
        </StackPanel>

        <!-- ═══ Row 1: Summary ═════════════════════════════════════════ -->
        <StackPanel Grid.Row="1"
                    Orientation="Horizontal"
                    Margin="0,0,0,8">
            <TextBlock Text="Duration: "
                       Foreground="#FFAAAAAA"/>
            <TextBlock x:Name="DurationText"
                       Foreground="White"/>
            <TextBlock Text="  │  Stokes: "
                       Foreground="#FFAAAAAA"
                       Margin="16,0,0,0"/>
            <TextBlock x:Name="StokesCountText"
                       Foreground="White"/>
            <TextBlock Text="  │  Raw audio: "
                       Foreground="#FFAAAAAA"
                       Margin="16,0,0,0"/>
            <TextBlock x:Name="RawCountText"
                       Foreground="White"/>
            <TextBlock Text="  │  Processed: "
                       Foreground="#FFAAAAAA"
                       Margin="16,0,0,0"/>
            <TextBlock x:Name="ProcessedCountText"
                       Foreground="White"/>
        </StackPanel>

        <!-- ═══ Row 2: Poincaré sphere playback ═══════════════════════ -->
        <Border Grid.Row="2"
                BorderThickness="1"
                BorderBrush="#FF555555"
                CornerRadius="4"
                Margin="0,0,0,6">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Text="Poincaré Playback"
                           Foreground="White"
                           FontWeight="Bold"
                           Margin="10,6"/>

                <h:HelixViewport3D x:Name="PlaybackView"
                                   Grid.Row="1"
                                   ShowCoordinateSystem="True"
                                   CoordinateSystemLabelForeground="White"/>

                <StackPanel Grid.Row="2"
                            Margin="10,6">
                    <StackPanel Orientation="Horizontal"
                                Margin="0,0,0,4">
                        <Button x:Name="SpherePlayBtn"
                                Content="▶  Play"
                                Style="{StaticResource DarkButton}"
                                FontSize="12"
                                Padding="12,5"
                                Click="SpherePlay_Click"/>
                        <Button Content="⏹  Stop"
                                Style="{StaticResource DarkButton}"
                                FontSize="12"
                                Padding="12,5"
                                Margin="6,0"
                                Click="SphereStop_Click"/>
                        <Button Content="⏪ −5 s"
                                Style="{StaticResource DarkButton}"
                                FontSize="11"
                                Padding="10,5"
                                Margin="12,0,0,0"
                                Click="SphereBack_Click"/>
                        <Button Content="⏩ +5 s"
                                Style="{StaticResource DarkButton}"
                                FontSize="11"
                                Padding="10,5"
                                Margin="6,0"
                                Click="SphereFwd_Click"/>
                        <TextBlock x:Name="SphereTimeText"
                                   Text="0:00 / 0:00"
                                   Foreground="White"
                                   VerticalAlignment="Center"
                                   Margin="16,0,0,0"
                                   FontSize="14"
                                   FontWeight="SemiBold"/>
                    </StackPanel>
                    <Slider x:Name="SphereSlider"
                            Minimum="0"
                            Maximum="1"
                            ValueChanged="SphereSlider_ValueChanged"
                            Thumb.DragStarted="SphereSlider_DragStarted"
                            Thumb.DragCompleted="SphereSlider_DragCompleted"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══ Row 3: Processed Audio ═════════════════════════════════ -->
        <Border Grid.Row="3"
                BorderThickness="1"
                BorderBrush="#FF555555"
                CornerRadius="4"
                Margin="0,0,0,6"
                Padding="12,8">
            <StackPanel>
                <TextBlock Text="Processed Audio"
                           Foreground="White"
                           FontWeight="Bold"
                           Margin="0,0,0,4"/>
                <StackPanel Orientation="Horizontal"
                            Margin="0,0,0,4">
                    <Button x:Name="ProcPlayBtn"
                            Content="▶  Play"
                            Style="{StaticResource DarkButton}"
                            FontSize="11"
                            Padding="10,4"
                            Click="ProcPlay_Click"/>
                    <Button Content="⏹"
                            Style="{StaticResource DarkButton}"
                            FontSize="11"
                            Padding="10,4"
                            Margin="5,0"
                            Click="ProcStop_Click"/>
                    <Button Content="⏪ −5 s"
                            Style="{StaticResource DarkButton}"
                            FontSize="10"
                            Padding="8,4"
                            Margin="10,0,0,0"
                            Click="ProcBack_Click"/>
                    <Button Content="⏩ +5 s"
                            Style="{StaticResource DarkButton}"
                            FontSize="10"
                            Padding="8,4"
                            Margin="5,0"
                            Click="ProcFwd_Click"/>
                    <TextBlock x:Name="ProcTimeText"
                               Text="0:00 / 0:00"
                               Foreground="White"
                               VerticalAlignment="Center"
                               Margin="12,0,0,0"
                               FontSize="13"/>
                    <TextBlock Text="  Vol:"
                               Foreground="#FFAAAAAA"
                               VerticalAlignment="Center"
                               Margin="12,0,4,0"/>
                    <Slider x:Name="ProcVolumeSlider"
                            Width="90"
                            Minimum="0"
                            Maximum="1"
                            Value="1"
                            VerticalAlignment="Center"
                            ValueChanged="ProcVolume_Changed"/>
                    <TextBlock x:Name="ProcStatusText"
                               Text=""
                               Foreground="#FFAAAAAA"
                               VerticalAlignment="Center"
                               Margin="10,0,0,0"/>
                </StackPanel>
                <Slider x:Name="ProcSlider"
                        Minimum="0"
                        Maximum="1"
                        ValueChanged="ProcSlider_ValueChanged"
                        Thumb.DragStarted="ProcSlider_DragStarted"
                        Thumb.DragCompleted="ProcSlider_DragCompleted"/>
                <MediaElement x:Name="ProcessedMedia"
                              LoadedBehavior="Manual"
                              UnloadedBehavior="Manual"
                              Volume="1"
                              MediaOpened="ProcMedia_Opened"
                              MediaFailed="Media_Failed"
                              MediaEnded="ProcMedia_Ended"/>
            </StackPanel>
        </Border>

        <!-- ═══ Row 4: Raw Reference Audio ═════════════════════════════ -->
        <Border Grid.Row="4"
                BorderThickness="1"
                BorderBrush="#FF555555"
                CornerRadius="4"
                Margin="0,0,0,6"
                Padding="12,8">
            <StackPanel>
                <TextBlock Text="Raw Reference Audio"
                           Foreground="White"
                           FontWeight="Bold"
                           Margin="0,0,0,4"/>
                <StackPanel Orientation="Horizontal"
                            Margin="0,0,0,4">
                    <Button x:Name="RawPlayBtn"
                            Content="▶  Play"
                            Style="{StaticResource DarkButton}"
                            FontSize="11"
                            Padding="10,4"
                            Click="RawPlay_Click"/>
                    <Button Content="⏹"
                            Style="{StaticResource DarkButton}"
                            FontSize="11"
                            Padding="10,4"
                            Margin="5,0"
                            Click="RawStop_Click"/>
                    <Button Content="⏪ −5 s"
                            Style="{StaticResource DarkButton}"
                            FontSize="10"
                            Padding="8,4"
                            Margin="10,0,0,0"
                            Click="RawBack_Click"/>
                    <Button Content="⏩ +5 s"
                            Style="{StaticResource DarkButton}"
                            FontSize="10"
                            Padding="8,4"
                            Margin="5,0"
                            Click="RawFwd_Click"/>
                    <TextBlock x:Name="RawTimeText"
                               Text="0:00 / 0:00"
                               Foreground="White"
                               VerticalAlignment="Center"
                               Margin="12,0,0,0"
                               FontSize="13"/>
                    <TextBlock Text="  Vol:"
                               Foreground="#FFAAAAAA"
                               VerticalAlignment="Center"
                               Margin="12,0,4,0"/>
                    <Slider x:Name="RawVolumeSlider"
                            Width="90"
                            Minimum="0"
                            Maximum="1"
                            Value="1"
                            VerticalAlignment="Center"
                            ValueChanged="RawVolume_Changed"/>
                    <TextBlock x:Name="RawStatusText"
                               Text=""
                               Foreground="#FFAAAAAA"
                               VerticalAlignment="Center"
                               Margin="10,0,0,0"/>
                </StackPanel>
                <Slider x:Name="RawSlider"
                        Minimum="0"
                        Maximum="1"
                        ValueChanged="RawSlider_ValueChanged"
                        Thumb.DragStarted="RawSlider_DragStarted"
                        Thumb.DragCompleted="RawSlider_DragCompleted"/>
                <MediaElement x:Name="RawMedia"
                              LoadedBehavior="Manual"
                              UnloadedBehavior="Manual"
                              Volume="1"
                              MediaOpened="RawMedia_Opened"
                              MediaFailed="Media_Failed"
                              MediaEnded="RawMedia_Ended"/>
            </StackPanel>
        </Border>

        <!-- ═══ Row 5: New Measurement ═════════════════════════════════ -->
        <Button Grid.Row="5"
                Content="New Measurement"
                Style="{StaticResource AccentButton}"
                FontSize="14"
                Padding="20,9"
                HorizontalAlignment="Center"
                Margin="0,4,0,0"
                Click="NewMeasurement_Click"/>
    </Grid>
</UserControl>
